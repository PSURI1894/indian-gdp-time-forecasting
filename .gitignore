# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/

# Jupyter
.ipynb_checkpoints/

# Data: the small *processed* CSVs ARE tracked, so the committed notebook outputs
# stay reproducible even if World Bank / OECD later revise the figures. Raw
# source snapshots are ignored (regenerate with `python -m src.data`).
data/raw/*.csv

# Reports/figures are regenerated by the notebooks.
reports/figures/*.png

# OS
Thumbs.db
.DS_Store
